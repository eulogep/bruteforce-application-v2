# BruteForce Tool - Variables d'environnement
# @author MABIALA EULOGE JUNIOR

# Configuration API Backend
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000

# Configuration de l'application
VITE_APP_NAME=BruteForce Tool
VITE_APP_VERSION=2.0.0
VITE_APP_AUTHOR=MABIALA EULOGE JUNIOR

# Mode développement/production
VITE_DEV_MODE=true
VITE_ENABLE_ANALYTICS=false

# Configuration des performances
VITE_ENABLE_PWA=false
VITE_ENABLE_SERVICE_WORKER=false

# Configuration de sécurité
VITE_ENABLE_DEMO_MODE=true
VITE_MAX_ATTACK_DURATION=3600

# Configuration des logs
VITE_LOG_LEVEL=info
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Configuration des fonctionnalités
VITE_ENABLE_GPU_SUPPORT=true
VITE_ENABLE_ADVANCED_ANALYSIS=true
VITE_ENABLE_EXPORT_FEATURES=true
